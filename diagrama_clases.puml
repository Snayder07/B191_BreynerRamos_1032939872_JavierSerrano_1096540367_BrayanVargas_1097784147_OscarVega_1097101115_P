@startuml Kampets_DiagramaClases

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classFontName Arial
skinparam classHeaderBackgroundColor #d4edda
skinparam classBorderColor #166534
skinparam packageBorderColor #166534
skinparam packageFontColor #166534
skinparam packageFontSize 13
skinparam ArrowColor #166534
skinparam linetype ortho

' ══════════════════════════════════════════
'  PAQUETE: util
' ══════════════════════════════════════════
package "util" {

    class ConexionBD {
        - url          : String
        - user         : String
        - pass         : String
        - connection   : Connection
        - stmtConsulta : Statement
        + ConexionBD()
        + getConnection()              : Connection
        + insertarBD(sql : String)     : boolean
        + consultarBD(sql : String)    : ResultSet
        + actualizarBD(sql : String)   : boolean
        + borrarBD(sql : String)       : boolean
        + setAutoCommitBD(val : boolean) : boolean
        + commitBD()                   : boolean
        + rollbackBD()                 : boolean
        + cerrarConexion()             : void
    }
}

' ══════════════════════════════════════════
'  PAQUETE: model
' ══════════════════════════════════════════
package "model" {

    interface Persistible <<interface>> {
        + insertarBD()   : boolean
        + actualizarBD() : boolean
        + eliminarBD()   : boolean
    }

    enum EstadoCita <<enumeration>> {
        PROGRAMADA
        CONFIRMADA
        PENDIENTE
        CANCELADA
        EN_ESPERA
        COMPLETADA
    }

    abstract class Persona <<abstract>> {
        # nombre   : String
        # telefono : String
        # correo   : String
        + getNombre()             : String
        + getTelefono()           : String
        + getCorreo()             : String
        + setNombre(n : String)   : void
        + setTelefono(t : String) : void
        + setCorreo(c : String)   : void
    }

    class Cliente {
        - id            : Integer
        - direccion     : String
        - contrasena    : String
        - fechaRegistro : LocalDate
        + getId()                : Integer
        + getDireccion()         : String
        + getContrasena()        : String
        + getFechaRegistro()     : LocalDate
        + setId(id : Integer)    : void
        + setDireccion(d : String)   : void
        + setContrasena(c : String)  : void
        + setFechaRegistro(f : LocalDate) : void
        + insertarBD()           : boolean
        + actualizarBD()         : boolean
        + eliminarBD()           : boolean
        + {static} consultarTodosBD()              : List<Cliente>
        + {static} buscarPorCorreoBD(correo : String) : Cliente
        + {static} buscarPorIdBD(id : int)         : Cliente
    }

    class Empleados {
        - id         : Integer
        - apellido   : String
        - cargo      : String
        - contrasena : String
        + getId()        : Integer
        + getNombre()    : String
        + getApellido()  : String
        + getCargo()     : String
        + getContrasena(): String
        + setId(id : Integer)        : void
        + setApellido(ap : String)   : void
        + setCargo(cargo : String)   : void
        + setContrasena(c : String)  : void
        + insertarBD()   : boolean
        + actualizarBD() : boolean
        + eliminarBD()   : boolean
        + {static} consultarTodosBD()              : List<Empleados>
        + {static} buscarPorCorreoBD(correo : String) : Empleados
    }

    class Especies {
        - id     : Integer
        - nombre : String
        + getId()              : Integer
        + getNombre()          : String
        + setId(id : Integer)  : void
        + setNombre(n : String): void
        + insertarBD()         : boolean
        + {static} consultarTodosBD()                   : List<Especies>
        + {static} buscarPorNombreBD(nombre : String)   : Especies
        + {static} buscarPorIdBD(id : int)              : Especies
    }

    class Mascotas {
        - id             : Integer
        - nombre         : String
        - sexo           : String
        - caracteristica : String
        - fechaNac       : LocalDate
        - cliente        : Cliente
        - especie        : Especies
        + getId()              : Integer
        + getNombre()          : String
        + getSexo()            : String
        + getCaracteristica()  : String
        + getFechaNac()        : LocalDate
        + getCliente()         : Cliente
        + getEspecie()         : Especies
        + getEtiqueta()        : String
        + setId(id : Integer)          : void
        + setNombre(n : String)        : void
        + setSexo(s : String)          : void
        + setCaracteristica(c : String): void
        + setFechaNac(f : LocalDate)   : void
        + setCliente(c : Cliente)      : void
        + setEspecie(e : Especies)     : void
        + insertarBD()   : boolean
        + actualizarBD() : boolean
        + eliminarBD()   : boolean
        + {static} consultarTodosBD()              : List<Mascotas>
        + {static} consultarPorClienteBD(id : int) : List<Mascotas>
        + {static} buscarPorIdBD(id : Integer)     : Mascotas
    }

    class Vacunas {
        - id          : Integer
        - nombre      : String
        - descripcion : String
        + getId()              : Integer
        + getNombre()          : String
        + getDescripcion()     : String
        + setId(id : Integer)  : void
        + setNombre(n : String): void
        + setDescripcion(d : String) : void
        + {static} consultarTodosBD() : List<Vacunas>
    }

    class Servicio {
        - id           : Integer
        - nombre       : String
        - descripcion  : String
        - precio       : BigDecimal
        - duracionMin  : Integer
        + getId()              : Integer
        + getNombre()          : String
        + getDescripcion()     : String
        + getPrecio()          : BigDecimal
        + getDuracionMin()     : Integer
        + setId(id : Integer)  : void
        + setNombre(n : String): void
        + setDescripcion(d : String) : void
        + setPrecio(p : BigDecimal)  : void
        + setDuracionMin(min : Integer) : void
        + {static} consultarTodosBD() : List<Servicio>
    }

    class Citas {
        - id                 : Integer
        - fechaCita          : LocalDate
        - horaCita           : LocalTime
        - estadoCita         : EstadoCita
        - motivo             : String
        - direccionDomicilio : String
        - mascota            : Mascotas
        - empleado           : Empleados
        + getId()                  : Integer
        + getFechaCita()           : LocalDate
        + getHoraCita()            : LocalTime
        + getEstadoCita()          : EstadoCita
        + getMotivo()              : String
        + getDireccionDomicilio()  : String
        + getMascota()             : Mascotas
        + getEmpleado()            : Empleados
        + getServicios()           : List<Cita_servicio>
        + setId(id : Integer)                      : void
        + setFechaCita(f : LocalDate)              : void
        + setHoraCita(h : LocalTime)               : void
        + setEstadoCita(e : EstadoCita)            : void
        + setMotivo(m : String)                    : void
        + setDireccionDomicilio(d : String)        : void
        + setMascota(m : Mascotas)                 : void
        + setEmpleado(e : Empleados)               : void
        + insertarBD()   : boolean
        + actualizarBD() : boolean
        + eliminarBD()   : boolean
        + {static} actualizarEstadoBD(id : Integer, e : EstadoCita) : boolean
        + {static} consultarTodosBD()                              : List<Citas>
        + {static} consultarPorClienteBD(id : int)                 : List<Citas>
        + {static} consultarPasadasPorClienteBD(id : int)          : List<Citas>
        + {static} consultarDeHoyBD()                              : List<Citas>
        + {static} consultarVacunasBD()                            : List<Citas>
        + {static} buscarPorIdBD(id : Integer)                     : Citas
    }

    class Cita_servicio {
        - id            : Integer
        - cita          : Citas
        - servicio      : Servicio
        - precioCobrado : BigDecimal
        + getId()             : Integer
        + getCita()           : Citas
        + getServicio()       : Servicio
        + getPrecioCobrado()  : BigDecimal
        + setId(id : Integer)              : void
        + setCita(c : Citas)               : void
        + setServicio(s : Servicio)        : void
        + setPrecioCobrado(p : BigDecimal) : void
        + insertarBD() : boolean
        + {static} consultarPorCitaBD(citaId : int) : List<Cita_servicio>
    }

    class Control_vacunas {
        - id              : Integer
        - fechaAplicacion : LocalDate
        - proximaDosis    : LocalDate
        - mascota         : Mascotas
        - vacuna          : Vacunas
        + getId()               : Integer
        + getFechaAplicacion()  : LocalDate
        + getProximaDosis()     : LocalDate
        + getMascota()          : Mascotas
        + getVacuna()           : Vacunas
        + getEstado()           : String
        + setId(id : Integer)                  : void
        + setFechaAplicacion(f : LocalDate)    : void
        + setProximaDosis(p : LocalDate)       : void
        + setMascota(m : Mascotas)             : void
        + setVacuna(v : Vacunas)               : void
        + insertarBD()   : boolean
        + actualizarBD() : boolean
        + eliminarBD()   : boolean
        + {static} consultarTodosBD()              : List<Control_vacunas>
        + {static} consultarPorClienteBD(id : int) : List<Control_vacunas>
    }

    class Productos {
        - id     : Integer
        - nombre : String
        - tipo   : String
        - marca  : String
        - precio : BigDecimal
        - stock  : Integer
        - foto   : byte[]
        + getId()              : Integer
        + getNombre()          : String
        + getTipo()            : String
        + getMarca()           : String
        + getPrecio()          : BigDecimal
        + getStock()           : Integer
        + getFoto()            : byte[]
        + setId(id : Integer)      : void
        + setNombre(n : String)    : void
        + setTipo(t : String)      : void
        + setMarca(m : String)     : void
        + setPrecio(p : BigDecimal): void
        + setStock(s : Integer)    : void
        + setFoto(f : byte[])      : void
        + insertarBD()   : boolean
        + actualizarBD() : boolean
        + eliminarBD()   : boolean
        + {static} consultarTodosBD() : List<Productos>
    }

    class Pedidos {
        - id          : Integer
        - cliente     : Cliente
        - fechaPedido : LocalDate
        - totalPedido : BigDecimal
        + getId()                      : Integer
        + getCliente()                 : Cliente
        + getFechaPedido()             : LocalDate
        + getTotalPedido()             : BigDecimal
        + setId(id : Integer)          : void
        + setCliente(c : Cliente)      : void
        + setFechaPedido(f : LocalDate): void
        + setTotalPedido(t : BigDecimal): void
    }

    class Detalle_pedido {
        - id             : Integer
        - pedido         : Pedidos
        - producto       : Productos
        - cantidad       : Integer
        - precioUnitario : BigDecimal
        + getId()                          : Integer
        + getPedido()                      : Pedidos
        + getProducto()                    : Productos
        + getCantidad()                    : Integer
        + getPrecioUnitario()              : BigDecimal
        + setId(id : Integer)              : void
        + setPedido(p : Pedidos)           : void
        + setProducto(p : Productos)       : void
        + setCantidad(c : Integer)         : void
        + setPrecioUnitario(p : BigDecimal): void
    }
}

' ══════════════════════════════════════════
'  PAQUETE: service
' ══════════════════════════════════════════
package "service" {

    class ConfigService {
        + {static} get(clave : String, valorPorDefecto : String) : String
        + {static} getEmailRemitente()   : String
        + {static} getSmtpLogin()        : String
        + {static} getEmailPassword()    : String
        + {static} isCorreoConfigurado() : boolean
        + {static} setEmailCredenciales(emailRemitente : String,\n  smtpLogin : String, password : String,\n  host : String, port : String) : void
        + {static} setEmailCredenciales(email : String,\n  password : String, host : String, port : String) : void
    }

    class ClienteService {
        + registrar(nombre : String, apellido : String,\n  correo : String, telefono : String,\n  contrasena : String, confirmar : String) : void
        + loginCliente(correo : String, contrasena : String) : Cliente
        + buscarPorCorreo(correo : String) : Cliente
        + listarTodos() : List<Cliente>
    }

    class CorreoService {
        + {static} enviarCodigoRecuperacion(destinatario : String,\n  nombreCliente : String, codigo : String) : void
        + {static} enviarCorreoGeneral(destinatario : String,\n  nombreCliente : String, asunto : String,\n  cuerpoHtml : String) : void
    }

    class RecuperacionService {
        - codigosPendientes : Map<String, String>
        - esEmpleado        : Map<String, Boolean>
        + enviarCodigoRecuperacion(correo : String) : void
        + verificarCodigo(correo : String, codigoIngresado : String) : boolean
        + cambiarContrasena(correo : String,\n  nueva : String, confirmar : String) : void
    }
}

' ══════════════════════════════════════════
'  PAQUETE: controller
' ══════════════════════════════════════════
package "controller" {

    class LoginController {
        + loginCliente(correo : String, contrasena : String,\n  panel : JPanel) : Cliente
        + loginAdmin(correo : String, contrasena : String,\n  panel : JPanel) : void
    }

    class RegistroController {
        - clienteService : ClienteService
        + registrar(nombre : String, apellido : String,\n  correo : String, telefono : String,\n  contrasena : String, confirmar : String,\n  panel : JPanel) : void
    }

    class CitaAdminController {
        + listarTodas()                          : List<Citas>
        + listarPorCliente(id : Integer)         : List<Citas>
        + listarPasadasPorCliente(id : Integer)  : List<Citas>
        + listarDeHoy()                          : List<Citas>
        + listarCitasVacunas()                   : List<Citas>
        + listarMascotas()                       : List<Mascotas>
        + listarEmpleados()                      : List<Empleados>
        + confirmarCita(id : Integer, panel : JPanel) : void
        + cancelarCita(id : Integer, panel : JPanel)  : void
        + cambiarEstado(id : Integer,\n  estado : EstadoCita, panel : JPanel) : void
        + guardarCita(mascota : Mascotas,\n  empleado : Empleados, fechaStr : String,\n  horaStr : String, estadoStr : String,\n  panel : JPanel) : boolean
    }

    class AgendarCitaController {
        + listarMascotas()     : List<Mascotas>
        + listarServicios()    : List<Servicio>
        + listarVeterinarios() : List<Empleados>
        + guardarCita(mascota : Mascotas,\n  empleado : Empleados, fechaStr : String,\n  horaStr : String, direccion : String,\n  motivo : String, panel : JPanel) : boolean
    }

    class MascotaAdminController {
        + listarTodas()                            : List<Mascotas>
        + listarEspecies()                         : List<Especies>
        + obtenerOCrearEspecie(nombre : String)    : Especies
        + listarClientes()                         : List<Cliente>
        + registrarMascota(nombre : String,\n  especie : Especies, cliente : Cliente,\n  fechaNacStr : String, sexo : String,\n  car : String, panel : JPanel) : boolean
        + actualizarMascota(mascota : Mascotas,\n  nombre : String, especie : Especies,\n  fecha : LocalDate, sexo : String,\n  panel : JPanel) : void
        + eliminarMascota(id : Integer, panel : JPanel) : void
    }

    class InventarioController {
        + listarTodos()                            : List<Productos>
        + agregarProducto(nombre : String,\n  tipo : String, marca : String,\n  precio : String, stock : String,\n  foto : byte[], panel : JPanel) : boolean
        + actualizarProducto(p : Productos,\n  panel : JPanel) : boolean
        + eliminarProducto(id : Integer, panel : JPanel) : void
    }

    class VacunaAdminController {
        + listarTodas()                                      : List<Control_vacunas>
        + listarVacunas()                                    : List<Vacunas>
        + listarMascotas()                                   : List<Mascotas>
        + guardar(cv : Control_vacunas)                      : void
        + actualizar(cv : Control_vacunas)                   : void
        + eliminar(id : Integer)                             : void
        + eliminarConCancelacion(cv : Control_vacunas,\n  panel : JPanel) : void
        + listarCitasVacunSinRegistro()                      : List<Citas>
    }
}

