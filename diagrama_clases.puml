    }

    class PanelMisCitas {
        + panel : JPanel
        + PanelMisCitas()
        + recargar() : void
    }

    class PanelMisMascotas {
        + panel : JPanel
        + PanelMisMascotas()
        + recargar() : void
    }

    class PanelHistorial {
        + panel : JPanel
        + PanelHistorial()
        + recargar() : void
    }

    class PanelAlimentos {
        + panel : JPanel
        - ctrl  : InventarioController
        + PanelAlimentos()
        + recargar() : void
    }

    class PanelVacunas {
        + panel : JPanel
        + PanelVacunas()
        + recargar() : void
    }
}

' ══════════════════════════════════════════
'  RELACIONES
' ══════════════════════════════════════════

' --- Herencia ---
Persona  <|-- Cliente
Persona  <|-- Empleados

' --- Realización de interfaz ---
Persistible <|.. Cliente
Persistible <|.. Empleados
Persistible <|.. Mascotas
Persistible <|.. Citas
Persistible <|.. Control_vacunas
Persistible <|.. Productos

' --- Enumeración ---
Citas ..> EstadoCita

' --- Composición (Cita_servicio no existe sin Citas) ---
Citas "1" *-- "0..*" Cita_servicio : contiene >

' --- Agregación ---
Mascotas        "0..*" o-- "1"    Cliente   : pertenece a >
Mascotas        "0..*" o-- "1"    Especies  : es de >
Citas           "0..*" o-- "1"    Mascotas  : es de >
Citas           "0..*" o-- "1"    Empleados : atendida por >
Control_vacunas "0..*" o-- "1"    Mascotas  : registrada para >
Control_vacunas "0..*" o-- "1"    Vacunas   : tipo >
Cita_servicio   "0..*" o-- "1"    Servicio  : de tipo >
Pedidos         "0..*" o-- "1"    Cliente   : realizado por >
Detalle_pedido  "0..*" o-- "1"    Pedidos   : parte de >
Detalle_pedido  "0..*" o-- "1"    Productos : contiene >

' --- Dependencia modelo → ConexionBD ---
Cliente         ..> ConexionBD
Empleados       ..> ConexionBD
Mascotas        ..> ConexionBD
Citas           ..> ConexionBD
Productos       ..> ConexionBD
Control_vacunas ..> ConexionBD
Especies        ..> ConexionBD
Vacunas         ..> ConexionBD
Servicio        ..> ConexionBD
Cita_servicio   ..> ConexionBD

' --- Dependencia service → model / service ---
ClienteService      ..> Cliente
RecuperacionService ..> Cliente
RecuperacionService ..> Empleados
RecuperacionService ..> CorreoService
CorreoService       ..> ConfigService

' --- Dependencia controller → service / model ---
RegistroController    ..> ClienteService
LoginController       ..> Cliente
LoginController       ..> Empleados
CitaAdminController   ..> Citas
CitaAdminController   ..> Mascotas
CitaAdminController   ..> Empleados
AgendarCitaController ..> Citas
AgendarCitaController ..> Mascotas
AgendarCitaController ..> Servicio
AgendarCitaController ..> Empleados
MascotaAdminController ..> Mascotas
MascotaAdminController ..> Especies
MascotaAdminController ..> Cliente
InventarioController   ..> Productos
VacunaAdminController  ..> Control_vacunas
VacunaAdminController  ..> Mascotas
VacunaAdminController  ..> Vacunas

' --- Dependencia view → controller (agregación) ---
PanelAdmin           o-- CitaAdminController
PanelAdmin           o-- VacunaAdminController
PanelCliente         o-- CitaAdminController
PanelAdminCitas      o-- CitaAdminController
PanelAdminMascotas   o-- MascotaAdminController
PanelAdminInventario o-- InventarioController
PanelAdminVacunas    o-- VacunaAdminController
PanelAgendarCita     o-- AgendarCitaController
PanelAlimentos       o-- InventarioController

' --- Dependencia view → controller (uso directo) ---
PanelAdminReportes ..> CitaAdminController
PanelAdminReportes ..> InventarioController
PanelAdminReportes ..> MascotaAdminController
PanelAdminReportes ..> VacunaAdminController
PanelMisCitas      ..> CitaAdminController
PanelMisMascotas   ..> MascotaAdminController
PanelHistorial     ..> CitaAdminController
PanelVacunas       ..> Control_vacunas
PanelVacunas       ..> Mascotas

' --- Dependencia view login/registro ---
Interfaz_Grafica_Kampets o-- LoginController
CrearCuenta              o-- RegistroController
RecuperacionContrasenaDialog o-- RecuperacionService
ConfigurarCorreoDialog   ..> ConfigService

' --- Main crea / gestiona todos los paneles ---
Main ..> PanelAdmin
