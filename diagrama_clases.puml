package "view" {

    class Main {
        + {static} clienteActual         : Cliente
        + {static} empleadoActual        : Empleados
        - {static} panelCliente          : PanelCliente
        - {static} panelAdmin            : PanelAdmin
        - {static} panelAdminCitas       : PanelAdminCitas
        - {static} panelAdminMascotas    : PanelAdminMascotas
        - {static} panelAdminVacunas     : PanelAdminVacunas
        - {static} panelAdminInventario  : PanelAdminInventario
        - {static} panelAdminReportes    : PanelAdminReportes
        - {static} panelCalendario       : PanelCalendario
        - {static} panelMisCitas         : PanelMisCitas
        - {static} panelHistorial        : PanelHistorial
        - {static} panelAlimentos        : PanelAlimentos
        - {static} panelVacunas          : PanelVacunas
